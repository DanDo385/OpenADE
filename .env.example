# OpenADE local development defaults
OPENADE_PORT=8080
OPENADE_DB_PATH=./backend/openade.db
VITE_API_URL=http://localhost:8080

# Optional provider bootstrap for browser/dev usage.
# If OPENAI_API_KEY is set, the backend will use it as a fallback provider
# when nothing has been saved yet in Settings.
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_DEFAULT_MODEL=gpt-4o-mini
